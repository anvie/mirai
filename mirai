#!/usr/bin/env bash
set -e

# ─── Mirai Node Manager ───
# Usage:
#   ./mirai start                  # Start primary node
#   ./mirai spawn worker           # Spawn a new node named "worker"
#   ./mirai spawn analytics 4001   # Spawn on custom port
#   ./mirai stop                   # Stop all nodes
#   ./mirai ps                     # List running nodes
#   ./mirai setup                  # Run onboarding wizard
#   ./mirai logs [name]            # Tail logs
#   ./mirai shell [name]           # Open IEx shell on a node

COOKIE="${MIRAI_COOKIE:-mirai_secret}"
IMAGE="elixir:1.16"
NETWORK="mirai_net"
PROJECT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Ensure network exists
ensure_network() {
  docker network inspect "$NETWORK" >/dev/null 2>&1 || \
    docker network create "$NETWORK" >/dev/null
}

# Build the boot command (handles dev vs prod)
boot_cmd() {
  local node_name="$1"
  local base="mix local.hex --force && mix local.rebar --force && mix deps.get"
  local env="${MIX_ENV:-dev}"

  if [ "$env" = "dev" ]; then
    echo "$base && apt-get update -qq && apt-get install -y -qq inotify-tools > /dev/null 2>&1; iex --name $node_name --cookie $COOKIE -S mix run --no-halt"
  else
    echo "$base && elixir --name $node_name --cookie $COOKIE -S mix run --no-halt"
  fi
}

cmd_start() {
  ensure_network
  local port="${1:-4000}"
  echo "Starting primary node (mirai@primary) on port $port..."
  
  docker run -d \
    --name mirai_primary \
    --hostname primary \
    --network "$NETWORK" \
    -v "$PROJECT_DIR:/app" \
    -v "$PROJECT_DIR/data:/app/data" \
    -w /app \
    -p "$port:$port" \
    -e PORT="$port" \
    -e MIX_ENV="${MIX_ENV:-dev}" \
    "$IMAGE" \
    sh -c "$(boot_cmd mirai@primary)"

  echo "Primary node started. Dashboard: http://localhost:$port"
}

cmd_setup() {
  echo "Running Mirai interactive setup..."
  docker run -it --rm \
    -v "$PROJECT_DIR:/app" \
    -w /app \
    "$IMAGE" \
    sh -c "apt-get update -qq && apt-get install -y -qq rlwrap > /dev/null 2>&1 && mix local.hex --force && mix local.rebar --force && mix deps.get && rlwrap mix mirai.setup 2> >(grep -v 'rlwrap: error: read error on master pty: Input/output error' >&2)"
}

cmd_spawn() {
  local name="${1:?Usage: mirai spawn <name> [port]}"
  local port="${2:-}"

  local port="${2:-}"

  # If no port specified, read from config.yaml or default to 4000
  if [ -z "$port" ]; then
    port=$(grep -E '^port:' "$PROJECT_DIR/config.yaml" 2>/dev/null | cut -d: -f2 | tr -d '[:space:]')
    port="${port:-4000}"
  fi

  ensure_network
  echo "Spawning node: mirai@$name on port $port..."

  docker run -d \
    --name "mirai_$name" \
    --hostname "$name" \
    --network "$NETWORK" \
    -v "$PROJECT_DIR:/app" \
    -v "$PROJECT_DIR/data:/app/data" \
    -w /app \
    -e MIX_ENV="${MIX_ENV:-dev}" \
    -e PORT="$port" \
    -p "$port:$port" \
    "$IMAGE" \
    sh -c "$(boot_cmd mirai@$name)"

  echo "Node mirai@$name spawned."
  echo "Dashboard: http://localhost:$port"
  echo "Connect from primary: Node.connect(:\"mirai@$name\")"
}

cmd_stop() {
  echo "Stopping all Mirai nodes..."
  docker ps -a --filter "name=mirai_" --format '{{.Names}}' | xargs -r docker rm -f
  echo "All nodes stopped."
}

cmd_ps() {
  echo "Running Mirai nodes:"
  echo "────────────────────────────────────────"
  docker ps --filter "name=mirai_" --format 'table {{.Names}}\t{{.Status}}\t{{.Ports}}'
}

cmd_logs() {
  local name="${1:-primary}"
  docker logs -f "mirai_$name"
}

cmd_shell() {
  local name="${1:-primary}"
  echo "Opening IEx shell on mirai_$name..."
  docker exec -it "mirai_$name" \
    iex --name "shell@$name" --cookie "$COOKIE" --remsh "mirai@$name"
}

cmd_help() {
  cat <<EOF
Mirai Node Manager

Usage: ./mirai <command> [args]

Commands:
  setup                 Run the interactive onboarding wizard
  start [port]          Start the primary node (default port: 4000)
  spawn <name> [port]   Spawn a new node with the given name
  stop                  Stop and remove all Mirai nodes
  ps                    List running nodes
  logs [name]           Tail logs for a node (default: primary)
  shell [name]          Open IEx remote shell on a node

Examples:
  ./mirai setup                  # Onboard and generate config.yaml
  ./mirai start                  # Start primary on port 4000
  ./mirai spawn worker           # Spawn node "worker"
  ./mirai spawn analytics 4001   # Spawn with dashboard port
  ./mirai shell worker           # Remote shell into worker
  ./mirai stop                   # Tear down everything

Environment:
  MIX_ENV=prod ./mirai start     # Start in production mode
  MIRAI_COOKIE=mysecret ./mirai start
EOF
}

# ─── Dispatch ───
case "${1:-help}" in
  setup) cmd_setup ;;
  start) cmd_start "$2" ;;
  spawn) cmd_spawn "$2" "$3" ;;
  stop)  cmd_stop ;;
  ps)    cmd_ps ;;
  logs)  cmd_logs "$2" ;;
  shell) cmd_shell "$2" ;;
  *)     cmd_help ;;
esac
